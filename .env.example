# ── Devin API ───────────────────────────────────────────────
# Service-user Bearer token (not needed for demo/replay mode)
DEVIN_API_KEY=
# Organization ID (prefix: org-)
DEVIN_ORG_ID=

# Set to 1 for replay mode (replays recorded real session payloads)
# Default: 1 — demo works out of the box without API credentials
DEVIN_REPLAY=1

# Set to 1 to record real session payloads into recordings/<identifier>.json
DEVIN_RECORD=0
# DEVIN_RECORDINGS_DIR=recordings

# ── Remediation session config ──────────────────────────────
PLAYBOOK_ID=playbook-... # Security Finding Remediation
MAX_CONCURRENCY=3              # Max parallel Devin sessions
MAX_ACU_LIMIT=10               # ACU budget per session

# ── GitHub (optional — demo works without these) ─────────────
# PAT with repo scope — only needed for real issue filing
GITHUB_TOKEN=
SUPERSET_FORK_REPO=michaelszhu/superset

# ── Database ────────────────────────────────────────────────
REMEDIATION_DB_PATH=/data/remediation.db
