# ── Devin API ───────────────────────────────────────────────
DEVIN_API_KEY=cog_...          # Service-user Bearer token
DEVIN_ORG_ID=org-...           # Organization ID (prefix: org-)

# Set to 1 to use MockDevinClient (replays recordings/*.json)
DEVIN_MOCK=0

# Set to 1 to record real session payloads into recordings/<identifier>.json
DEVIN_RECORD=0
# DEVIN_RECORDINGS_DIR=recordings   # override recording directory path

# ── Remediation session config ──────────────────────────────
PLAYBOOK_ID=playbook-7548a6acecb2417e94cb7a1050ab11bd  # Security Finding Remediation
MAX_CONCURRENCY=3              # Max parallel Devin sessions
MAX_ACU_LIMIT=10               # ACU budget per session

# ── GitHub ──────────────────────────────────────────────────
GITHUB_TOKEN=ghp_...           # PAT for PR creation / repo access
SUPERSET_FORK_REPO=michaelszhu/superset

# ── Database ────────────────────────────────────────────────
REMEDIATION_DB_PATH=/data/remediation.db
